# Supabase Configuration
# 获取方式：https://supabase.com/dashboard -> Project Settings -> API
COZE_SUPABASE_URL=https://your-project.supabase.co
COZE_SUPABASE_ANON_KEY=your-anon-key
COZE_SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# NextAuth Configuration
AUTH_SECRET=your-auth-secret-key-at-least-32-characters
NEXTAUTH_URL=http://localhost:5000

# CoinGecko API (免费，无需 key)
# 如果需要更高配额可以申请 API Key
COINGECKO_API_URL=https://api.coingecko.com/api/v3
